print("~nBuilding {"#"}~n~n");
onedrivefolder = getenv("onedrive");
baselib = "{onedrivefolder}\Documents\Programming\C\base\src";
print(baselib);
this = {
    src = quoteit({"{cwd}\..\bssEntryPoint.c"}),
    objs = {
        ""
    },
    libs = {
        ""
    },
};

exePath = "{cwd}\..\builds\bss.exe";

//if hasflag("-build")
{
    compiler = "cl";

    includeArg = join(
    {
        "/I{cwd}\..\",
        "/I{cwd}\..\..\",
    }, " ");

    outputName = "/Fe~"{exePath}~"";
    objFolder = "/Fo~"{"{cwd}\..\builds"}~"";
    src = join(this.src, " ");

    command = "{compiler} /Zi {includeArg} {src} {outputName} {objFolder} /Wall /wd4062 /wd4063 /wd4061 /wd4255 /wd4201 /wd4774 /wd4668 /wd4464 /wd5045 /wd4820 /DBUILD_CONSOLE_APP ";
    output = run command;

    print("{command}~n");
    print("{output.stdout}~n");
    print("{output.stderr}~n");
}

if hasflag("-test")
{
    print("{(run "~"{exePath}~"").out}");
}

print("~nFinished Building {"#"}~n");